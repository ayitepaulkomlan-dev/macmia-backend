# ── MACMIA Local — Variables d'environnement ─────────────────────────────────
# Copie ce fichier en .env dans le dossier backend/ et modifie selon tes besoins
# Les valeurs ci-dessous sont les valeurs par défaut

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Modèle principal — recommandations, chat, interview
# Options : mistral | llama3.1 | qwen2.5 | gemma2 | mixtral
MAIN_MODEL=llama3.1

# Modèle léger — extraction CV (plus rapide, moins coûteux en RAM)
# Options : phi3 | mistral | qwen2.5:3b
EXTRACTION_MODEL=phi3

# ── Génération ────────────────────────────────────────────────────────────────
MAIN_TEMPERATURE=0.2
EXTRACTION_TEMPERATURE=0.1
MAIN_MAX_TOKENS=2500
EXTRACTION_MAX_TOKENS=400

# ── Serveur ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info
